# .env.example — Frontend Despacho / Innovatech Chile
# ─────────────────────────────────────────────────────────────────────────
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena los valores según tu entorno
#   3. NUNCA subas .env a Git (está en .gitignore)
# ─────────────────────────────────────────────────────────────────────────

# ── URLs de APIs de los backends ─────────────────────────────────────────
# En PRODUCCIÓN con Docker + nginx: dejar VACÍOS
#   Las llamadas son relativas y nginx las proxea al backend privado
#
# En DESARROLLO LOCAL sin Docker: apuntar a localhost
#   VITE_VENTAS_URL=http://localhost:8080
#   VITE_DESPACHOS_URL=http://localhost:8081
VITE_VENTAS_URL=
VITE_DESPACHOS_URL=

# ── Docker Hub (para docker-compose local) ───────────────────────────────
DOCKERHUB_USERNAME=

# ── IP privada del backend EC2 (para nginx proxy en producción) ──────────
# Ejemplo: BACKEND_HOST=10.0.1.25
BACKEND_HOST=